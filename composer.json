{
    "name": "clarion-app/http-queue",
    "description": "Job queue for HTTP requests",
    "type": "library",
    "require": {
        "illuminate/support": "^11.0|^12.0",
        "illuminate/queue": "^11.0|^12.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "orchestra/testbench": "^9.0"
    },
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "ClarionApp\\HttpQueue\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ClarionApp\\HttpQueue\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Tim Schwartz",
            "email": "tim@metaverse.systems"
        }
    ],
    "extra": {
        "laravel": {
            "providers": [
                "ClarionApp\\HttpQueue\\HttpQueueServiceProvider"
            ]
        }
    }
}
